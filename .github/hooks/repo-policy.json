{
  "version": 1,
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 -m scripts.repo_policy --pre-tool-use",
        "cwd": ".",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "python3 -m scripts.repo_policy --pre-tool-use",
        "powershell": "python -m scripts.repo_policy --pre-tool-use",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
