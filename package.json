{
  "name": "slm-training-web",
  "private": true,
  "version": "0.1.0",
  "description": "Playground e2e + Playwright tooling for TwoTower annotate UI",
  "scripts": {
    "agentv": "agentv",
    "eval:agentv": "node scripts/run_agentv_eval.mjs",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install chromium",
    "annotate:serve": "python -m scripts.serve_playground --port 8765",
    "preview:install": "npm --prefix tools/openui_preview ci",
    "preview:build": "npm --prefix tools/openui_preview run build",
    "dashboard:install": "npm --prefix tools/dashboard install",
    "dashboard:build": "npm --prefix tools/dashboard run build"
  },
  "devDependencies": {
    "@agentv/core": "4.42.4",
    "@playwright/mcp": "0.0.78",
    "@playwright/test": "1.61.1",
    "agentv": "4.42.4"
  },
  "overrides": {
    "@opentelemetry/otlp-transformer": {
      "protobufjs": "8.7.1"
    }
  },
  "engines": {
    "node": ">=20 <23"
  }
}
