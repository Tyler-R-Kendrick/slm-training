# GPU multi-farm MCP (never commit real secrets)
VAST_API_KEY=
RUNPOD_API_KEY=
LAMBDA_API_KEY=

# Hugging Face Hub (required to sync full-train checkpoints to the OpenUI bucket)
# https://huggingface.co/buckets/TKendrick/OpenUI
HF_TOKEN=
# Optional override (default: hf://buckets/TKendrick/OpenUI)
SLM_CHECKPOINT_BUCKET=
# Set to 1 to force local-only checkpoints even on HF-context trains
SLM_DISABLE_CHECKPOINT_BUCKET=

# auto = live client when key set, else mock for that farm
# live = always use live clients (missing key returns missing_api_key)
# mock = always use deterministic mock offers
GPU_MULTI_FARM_MODE=auto

# Multiplier applied in project_training_cost for Cactus/runtime overhead
CACTUS_OVERHEAD=1.08
