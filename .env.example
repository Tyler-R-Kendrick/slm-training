# GPU multi-farm MCP (never commit real secrets)
VAST_API_KEY=
RUNPOD_API_KEY=
LAMBDA_API_KEY=

# Hugging Face Hub (required to sync full-train checkpoints to the OpenUI bucket)
# https://huggingface.co/buckets/TKendrick/OpenUI
HF_TOKEN=
# Optional override (default: hf://buckets/TKendrick/OpenUI)
SLM_CHECKPOINT_BUCKET=
# Set to 1 to force local-only checkpoints even on HF-context trains
SLM_DISABLE_CHECKPOINT_BUCKET=

# auto = live client when key set, else mock for that farm
# live = always use live clients (missing key returns missing_api_key)
# mock = always use deterministic mock offers
GPU_MULTI_FARM_MODE=auto

# Multiplier applied in project_training_cost for Cactus/runtime overhead
CACTUS_OVERHEAD=1.08

# Annotation playground (never commit real secrets)
SLM_ANNOTATION_TOKEN=
BLOB_READ_WRITE_TOKEN=

# Shared telemetry peers (docs/design/telemetry.md "Shared telemetry peers")
# Comma-separated peer URLs. Trainers broadcast OTLP to the FIRST peer (unless
# OTEL_EXPORTER_OTLP_ENDPOINT overrides); the dashboard read-federates ALL of
# them into the active-runs list and live streams.
SLM_OTEL_PEERS=
# Explicit OTLP mirror target for trainers (wins over SLM_OTEL_PEERS)
OTEL_EXPORTER_OTLP_ENDPOINT=
# Extra OTLP headers "k=v,k2=v2" (wins over the token fallbacks below)
OTEL_EXPORTER_OTLP_HEADERS=
# Ingest auth mode for THIS instance's hub: open (default) | token | hf
SLM_OTEL_AUTH=
# Shared bearer secret for token mode (senders pick it up automatically)
SLM_OTEL_TOKEN=
# Seconds between train.progress heartbeats from the train loop (0 disables)
SLM_OTEL_PROGRESS_SECONDS=
