# Offline rebuild inputs; the deployed control plane reads committed data/eval
# snapshots instead.
src/slm_training/resources/rico/**

# Offline governance mirrors duplicate committed records and are not read by
# the deployed control-plane APIs.
src/slm_training/resources/data/**/governance/**

# E530 r1 is retained only as invalid recipe-drift evidence. Production must
# expose the corrected immutable r2 snapshot, not this rejected candidate.
src/slm_training/resources/data/train/e530_visible_semantic_roles_r1_20260719/**

# SLM-230's bounded scratch corpus is experiment evidence, not a deployed
# dashboard dataset. Keep its 1.3 MB source/governance bundle offline.
src/slm_training/resources/data/train/slm230_symbol_only_v1/**

# Human narratives are served from the repository, not opened by the FastAPI
# function. Machine-readable experiment JSON remains deployable.
docs/design/**/*.md

# AgentV SDK bundles are durable review evidence, not dashboard runtime input.
# The compact top-level docs/design JSON remains available to observability.
docs/design/*-agentv-*/**

# Source maps are useful locally but are never served by the production app.
src/slm_training/web/static/**/*.map

# SLM-231's derivative library and bounded runner are offline experiment
# machinery. The deployed dashboard reads only their committed result JSON.
scripts/run_slm231_recurrence_dynamics.py
src/slm_training/harnesses/experiments/slm231_recurrence_dynamics.py

# SLM-243's architecture matrix runner and verdict contract are offline
# experiment machinery. The deployed dashboard consumes only its compact
# committed result JSON; full telemetry stays under the excluded AgentV path.
scripts/run_slm243_recursive_update_gate.py
src/slm_training/harnesses/experiments/slm243_recursive_update_gate.py

# SLM-233's matched recursive-depth campaign is offline experiment machinery.
# The deployed dashboard consumes only its compact top-level summary JSON.
scripts/run_slm233_recursive_campaign.py
src/slm_training/harnesses/experiments/slm233_recursive_campaign.py

# Predecessor recurrence fixture/audit runners are likewise offline. Their
# result JSON remains available to the deployed experiment reader.
scripts/run_slm138_recursive_denoiser_fixture.py
scripts/run_slm230_recurrence_observability.py
src/slm_training/harnesses/experiments/slm230_recurrence_observability.py

# The Vercel app only uses the frozen promotion engine; experiment runners are
# offline harnesses and otherwise pull their entire dependency tree into Lambda.
src/slm_training/harnesses/experiments/**
