# Offline rebuild inputs; the deployed control plane reads committed data/eval
# snapshots instead.
src/slm_training/resources/rico/**

# Offline governance mirrors duplicate committed records and are not read by
# the deployed control-plane APIs.
src/slm_training/resources/data/**/governance/**

# E530 r1 is retained only as invalid recipe-drift evidence. Production must
# expose the corrected immutable r2 snapshot, not this rejected candidate.
src/slm_training/resources/data/train/e530_visible_semantic_roles_r1_20260719/**

# SLM-230's bounded scratch corpus is experiment evidence, not a deployed
# dashboard dataset. Keep its 1.3 MB source/governance bundle offline.
src/slm_training/resources/data/train/slm230_symbol_only_v1/**

# Human narratives are served from the repository, not opened by the FastAPI
# function. Machine-readable experiment JSON remains deployable.
docs/design/**/*.md

# SLM-231's derivative library and bounded runner are offline experiment
# machinery. The deployed dashboard reads only their committed result JSON.
scripts/run_slm231_recurrence_dynamics.py
src/slm_training/harnesses/experiments/slm231_recurrence_dynamics.py
